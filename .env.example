# Auth0
AUTH0_DOMAIN=your-tenant.au.auth0.com
AUTH0_AUDIENCE=https://api.shedbooks.com
AUTH0_CLIENT_ID=your-spa-client-id

# Database
DB_PASSWORD=changeme
# Encryption key for field-level AES-256-GCM encryption (bank account details)
# Generate a new key with: openssl rand -base64 32
ENCRYPTION_KEY=xxxxxxxxx

# Client
API_URL=http://localhost:8080

# CORS — restrict to your frontend origin in production
CORS_ORIGIN=http://localhost:3000

# ABR Lookups
ABR_GUID=xxxxxxxxx
